# HiveTrace Environment Configuration
# Copy to .env.local for local development

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# App URLs (use your production domain on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HiveTrace

# Database — SQLite for local dev; use PostgreSQL on Vercel (Neon/Supabase)
DATABASE_URL=file:./dev.db

# Batch verification (HMAC-SHA256)
BATCH_HASH_SECRET=your-batch-hash-secret-here

# Paystack (test keys for development)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# Admin
ADMIN_EMAIL=admin@hivetrace.com

# Feature flags
NEXT_PUBLIC_ENABLE_FRAUD_DETECTION=true
NEXT_PUBLIC_ENABLE_GEO_VERIFICATION=true
NEXT_PUBLIC_ENABLE_REVIEWS=true

# Optional: file storage for batch images (Vercel Blob / S3)
NEXT_PUBLIC_STORAGE_URL=
STORAGE_API_KEY=
