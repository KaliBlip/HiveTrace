# HiveTrace Environment Configuration
# Copy this file to .env.local and fill in your actual values

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Supabase Configuration (for future database integration)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Batch Hash Secret (for HMAC-SHA256 verification)
BATCH_HASH_SECRET=your-batch-hash-secret-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HiveTrace

# Database Configuration (when using direct PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/hivetrace

# Storage Configuration (for QR codes and certificates)
NEXT_PUBLIC_STORAGE_URL=your-storage-url
STORAGE_API_KEY=your-storage-api-key

# Admin Configuration
ADMIN_EMAIL=admin@hivetrace.com

# Feature Flags
NEXT_PUBLIC_ENABLE_FRAUD_DETECTION=true
NEXT_PUBLIC_ENABLE_GEO_VERIFICATION=true
NEXT_PUBLIC_ENABLE_REVIEWS=true
